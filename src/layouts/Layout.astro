---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Senior Backend Engineer specializing in distributed systems, microservices architecture, and technical leadership." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/main.css" />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta name="description" content={description} />
    <meta property="og:image" content="/imgs/cartoon-me-pixel-art.webp" />
    <meta property="og:url" content="https://portfolio-duartebv.netlify.app/" />
    <link rel="canonical" href="https://portfolio-duartebv.netlify.app/" />
    <title>{title}</title>
  </head>
  <body class="bg-zinc-950 text-zinc-100 antialiased">
    <div class="min-h-screen flex flex-col">
      <Navbar />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
