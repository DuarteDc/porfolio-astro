---
import GithubIcon from "./icons/GithubIcon.astro";
import LinkedinIcon from "./icons/LinkedinIcon.astro";

const currentPath = Astro.url.pathname;
const isDemoPage = currentPath.startsWith("/demo");

const navLinks = [
  { href: "/#about", label: "About" },
  { href: "/#impact", label: "Impact" },
  { href: "/#case-studies", label: "Case Studies" },
  { href: "/#architecture", label: "Architecture" },
  { href: "/#experience", label: "Experience" },
  { href: "/#open-source", label: "Open Source" },
  { href: "/#contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-zinc-800/50 bg-zinc-950/80 backdrop-blur-lg">
  <nav class="max-w-6xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <a href="/" class="text-lg font-semibold text-zinc-100 tracking-tight hover:text-zinc-200 transition-colors">
        Eduardo<span class="text-zinc-500">.</span>
      </a>
      
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
      
      <div class="flex items-center gap-4">
        {isDemoPage && (
          <a
            href="/"
            class="md:hidden text-sm text-zinc-400 hover:text-zinc-100 transition-colors"
          >
            Back to Portfolio
          </a>
        )}
        <a
          href="https://github.com/DuarteDc"
          target="_blank"
          class="text-zinc-400 hover:text-zinc-100 transition-colors"
          aria-label="GitHub"
        >
          <GithubIcon width="20" height="20" />
        </a>
        <a
          href="https://mx.linkedin.com/in/duartedc"
          target="_blank"
          class="text-zinc-400 hover:text-zinc-100 transition-colors"
          aria-label="LinkedIn"
        >
          <LinkedinIcon width="20" height="20" />
        </a>
        <a
          href="/EduardoDuarteCv.pdf"
          download
          class="hidden md:inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-zinc-100 text-zinc-900 rounded-lg hover:bg-zinc-200 transition-colors"
        >
          Download CV
        </a>
      </div>
    </div>
  </nav>
</header>
