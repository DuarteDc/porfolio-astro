---
import MailIcon from "./icons/MailIcon.astro";
import GithubIcon from "./icons/GithubIcon.astro";
import LinkedinIcon from "./icons/LinkedinIcon.astro";
---

<section id="contact" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-sm font-medium text-zinc-500 uppercase tracking-widest mb-4">Get in Touch</p>
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-100 mb-6">
        Let's Work Together
      </h2>
      <p class="text-zinc-400 leading-relaxed mb-10">
        I'm currently open to opportunities in backend engineering, technical leadership, and system architecture. 
        If you're looking for someone who can design and lead complex systems in production, let's talk.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <a
          href="mailto:duartedc17@gmail.com"
          class="inline-flex items-center gap-3 px-6 py-3 bg-zinc-100 text-zinc-900 font-medium rounded-lg hover:bg-zinc-200 transition-colors w-full sm:w-auto justify-center"
        >
          <MailIcon width="18" height="18" />
          duartedc17@gmail.com
        </a>
        <a
          href="/EduardoDuarteCv.pdf"
          download
          class="inline-flex items-center gap-2 px-6 py-3 border border-zinc-700 text-zinc-300 font-medium rounded-lg hover:bg-zinc-800/50 transition-colors w-full sm:w-auto justify-center"
        >
          Download CV
        </a>
      </div>
      
      <div class="flex items-center justify-center gap-6">
        <a
          href="https://mx.linkedin.com/in/duartedc"
          target="_blank"
          class="flex items-center gap-2 text-zinc-400 hover:text-zinc-100 transition-colors"
        >
          <LinkedinIcon width="20" height="20" />
          <span class="text-sm">LinkedIn</span>
        </a>
        <a
          href="https://github.com/DuarteDc"
          target="_blank"
          class="flex items-center gap-2 text-zinc-400 hover:text-zinc-100 transition-colors"
        >
          <GithubIcon width="20" height="20" />
          <span class="text-sm">GitHub</span>
        </a>
      </div>
    </div>
  </div>
</section>
