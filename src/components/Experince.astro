---
import ExperienceItem from "./ExperienceItem.astro";

const experiences = [
  {
    title: "Jefe de Departamento — FGJEM",
    description: "Leading the Software Development department, managing technical teams and architectural decisions. Designed and implemented an evidence warehouse system using microservices architecture with Node.js, WebSockets, React, and Laravel + TypeScript. Built pre-denuncia en línea platform with Next.js, MySQL, Prisma, and Docker CI/CD. Maintained and developed the payroll system with automated GitHub Actions deployments and semantic versioning.",
    year: "May 2024 - Present"
  },
  {
    title: "Analista de Sistemas — IGECEM",
    description: "Developed a risk questionnaire system with PHP REST API, JWT authentication, PDF/Excel report generation, and hexagonal architecture for clean separation of concerns. Built the frontend with React, TypeScript, Tailwind CSS, and NextUI. Integrated CI/CD practices on Linux servers.",
    year: "Sep 2023 - May 2024"
  },
  {
    title: "Full Stack Developer — Digital Pineapple",
    description: "Built and scaled platforms serving thousands of users: course platform with Laravel, MySQL, and Livewire; e-commerce with Next.js, Tailwind, and Redux; REST APIs with hexagonal architecture using Node.js, Express, and MongoDB. Developed mobile applications with React Native integrating OAuth and WebSockets.",
    year: "May 2021 - May 2023"
  }
];
---

<section
  id="experience"
  class="w-full py-20 text-white xl:px-40 overflow-hidden normal-text"
>
  <h3
    class="bg-gradient-to-t from-purple-950 to-purple-100 inline-block text-transparent py-5 bg-clip-text text-4xl lg:text-6xl font-bold uppercase font-[Poppins] mb-12"
  >
    Experience
  </h3>
  <div class="grid gap-6">
    {experiences.map((exp) => (
      <ExperienceItem
        title={exp.title}
        description={exp.description}
        year={exp.year}
      />
    ))}
  </div>
</section>
