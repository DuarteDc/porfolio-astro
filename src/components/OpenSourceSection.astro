---
import ExternalLinkIcon from "./icons/ExternalLinkIcon.astro";
import GithubIcon from "./icons/GithubIcon.astro";
---

<section id="open-source" class="py-24 border-b border-zinc-800">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-sm font-medium text-zinc-500 uppercase tracking-widest mb-4">Open Source</p>
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-100">
        Side Projects
      </h2>
      <p class="mt-4 text-zinc-400 max-w-2xl mx-auto">
        Beyond client work, I contribute to the developer community through open source libraries and tools.
      </p>
    </div>
    
    <div class="max-w-3xl mx-auto">
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/50 overflow-hidden">
        <div class="p-8 border-b border-zinc-800">
          <div class="flex items-start justify-between gap-4">
            <div>
              <div class="flex items-center gap-3 mb-2">
                <h3 class="text-2xl font-bold text-zinc-100">stepper-ui</h3>
                <span class="px-2 py-1 text-xs font-medium text-emerald-400 bg-emerald-400/10 border border-emerald-400/20 rounded-full">
                  v1.2.5
                </span>
              </div>
              <p class="text-zinc-400 leading-relaxed">
                A React component library providing customizable, accessible stepper components for multi-step forms and workflows. Built with TypeScript and designed to integrate seamlessly with TailwindCSS.
              </p>
            </div>
          </div>
        </div>
        
        <div class="p-8 grid md:grid-cols-2 gap-8">
          <div>
            <h4 class="text-sm font-semibold text-zinc-400 uppercase tracking-wider mb-4">Features</h4>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-zinc-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-zinc-600 flex-shrink-0"></span>
                <span><strong class="text-zinc-100">TypeScript</strong> — Full type definitions out of the box</span>
              </li>
              <li class="flex items-start gap-3 text-zinc-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-zinc-600 flex-shrink-0"></span>
                <span><strong class="text-zinc-100">Validation</strong> — Sync and async step validation</span>
              </li>
              <li class="flex items-start gap-3 text-zinc-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-zinc-600 flex-shrink-0"></span>
                <span><strong class="text-zinc-100">Performant</strong> — Memoized to prevent re-renders</span>
              </li>
              <li class="flex items-start gap-3 text-zinc-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-zinc-600 flex-shrink-0"></span>
                <span><strong class="text-zinc-100">Accessible</strong> — Keyboard navigation support</span>
              </li>
            </ul>
          </div>
          
          <div>
            <h4 class="text-sm font-semibold text-zinc-400 uppercase tracking-wider mb-4">Stats</h4>
            <div class="grid grid-cols-2 gap-4">
              <div class="p-4 rounded-lg bg-zinc-800/50 border border-zinc-700/50">
                <p class="text-2xl font-bold text-zinc-100">186</p>
                <p class="text-xs text-zinc-500 mt-1">Weekly downloads</p>
              </div>
              <div class="p-4 rounded-lg bg-zinc-800/50 border border-zinc-700/50">
                <p class="text-2xl font-bold text-zinc-100">13</p>
                <p class="text-xs text-zinc-500 mt-1">Versions released</p>
              </div>
              <div class="p-4 rounded-lg bg-zinc-800/50 border border-zinc-700/50">
                <p class="text-2xl font-bold text-zinc-100">MIT</p>
                <p class="text-xs text-zinc-500 mt-1">License</p>
              </div>
              <div class="p-4 rounded-lg bg-zinc-800/50 border border-zinc-700/50">
                <p class="text-2xl font-bold text-zinc-100">6d</p>
                <p class="text-xs text-zinc-500 mt-1">Last update</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="px-8 py-6 bg-zinc-800/30 border-t border-zinc-800">
          <div class="flex flex-wrap items-center gap-4">
            <a
              href="https://www.npmjs.com/package/stepper-ui"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-zinc-300 border border-zinc-700 rounded-lg hover:bg-zinc-800 hover:border-zinc-600 transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M0 0h12v12H0V0zm12 12h12v12H12V12zM0 12v12h12V12H0zM4 4h4v4H4V4z"/>
              </svg>
              npm
              <ExternalLinkIcon width="12" height="12" />
            </a>
            <a
              href="https://github.com/DuarteDc/stepper-ui-library"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-zinc-300 border border-zinc-700 rounded-lg hover:bg-zinc-800 hover:border-zinc-600 transition-colors"
            >
              <GithubIcon width="16" height="16" />
              GitHub
              <ExternalLinkIcon width="12" height="12" />
            </a>
            <a
              href="/demo/stepper-ui"
              class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-zinc-300 border border-zinc-700 rounded-lg hover:bg-zinc-800 hover:border-zinc-600 transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Live Demo
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
