---
const {
  code = "",
  filename = "example.js",
  language = "javascript",
} = Astro.props;
---

<div class="code-box">
  <div class="code-header">
    <span class="file-icon">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
    </span>
    {filename}
  </div>
  <div class="code-body">
    <pre><code class={`language-${language}`}>{code}</code></pre>
  </div>
</div>

<style>
  .code-box {
    background: #18181b;
    border: 1px solid #27272a;
    border-radius: 8px;
    font-family: 'JetBrains Mono', monospace;
    overflow: hidden;
    margin: 1rem 0;
  }

  .code-header {
    background: #0f0f0f;
    color: #a1a1aa;
    padding: 10px 16px;
    border-bottom: 1px solid #27272a;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .file-icon {
    color: #71717a;
  }

  .code-body {
    padding: 0;
    overflow-x: auto;
  }

  pre {
    margin: 0;
    padding: 16px;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  code {
    font-family: 'JetBrains Mono', monospace;
  }
</style>
