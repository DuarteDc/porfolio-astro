---
interface Props {
  width?: number | string;
  height?: number | string;
  class?: string;
}

const { width = 24, height = 24, class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={width}
  height={height}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
>
  <path d="M19 12H5" />
  <path d="m12 19-7-7 7-7" />
</svg>
