---
const experiences = [
  {
    title: "Jefe de Departamento",
    company: "Fiscalía General de Justicia del Estado de México (FGJEM)",
    period: "May 2024 - Present",
    type: "Full-time",
    highlights: [
      "Leading a software development department with responsibility for architecture decisions and technical standards",
      "Managing the design and implementation of evidence warehouse system serving 50+ government agencies",
      "Overseeing CI/CD pipelines with automated deployments and semantic versioning",
      "Mentoring team members on microservices patterns and clean architecture"
    ],
    technologies: ["Node.js", "TypeScript", "React", "Laravel", "WebSockets", "Docker", "MySQL", "Kubernetes"]
  },
  {
    title: "Analista de Sistemas",
    company: "Instituto de Información e Investigación Geográfica, Estadística y Catastral (IGECEM)",
    period: "Sep 2023 - May 2024",
    type: "Full-time",
    highlights: [
      "Designed and built risk questionnaire system for government employee assessments",
      "Applied Hexagonal Architecture to separate domain logic from infrastructure",
      "Reduced report generation time by 60% through database query optimization",
      "Implemented JWT authentication and PDF/Excel report generation"
    ],
    technologies: ["PHP", "React", "TypeScript", "MySQL", "Tailwind CSS", "NextUI", "CI/CD"]
  },
  {
    title: "Full Stack Developer",
    company: "Digital Pineapple",
    period: "May 2021 - May 2023",
    type: "Full-time",
    highlights: [
      "Built e-commerce platform serving thousands of users with Next.js, Redux, and Node.js",
      "Developed hexagonal REST API architecture with Express and MongoDB",
      "Created mobile applications with React Native integrating OAuth and WebSockets",
      "Implemented course platform with Laravel, MySQL, and Livewire"
    ],
    technologies: ["Next.js", "React", "Node.js", "Laravel", "MongoDB", "React Native"]
  }
];
---

<section id="experience" class="py-24 border-b border-zinc-800">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-sm font-medium text-zinc-500 uppercase tracking-widest mb-4">Career Path</p>
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-100">
        Experience
      </h2>
    </div>
    
    <div class="relative">
      <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-zinc-800 -translate-x-1/2 hidden md:block"></div>
      
      <div class="space-y-12">
        {experiences.map((exp, index) => (
          <div class="relative grid md:grid-cols-2 gap-8 md:gap-12">
            <div class={`${index % 2 === 0 ? 'md:text-right md:pr-12' : 'md:col-start-2 md:text-left md:pl-12'}`}>
              {index % 2 === 0 && (
                <>
                  <p class="text-sm text-zinc-500 mb-2">{exp.period}</p>
                  <h3 class="text-xl font-semibold text-zinc-100">{exp.title}</h3>
                  <p class="text-zinc-400 mt-1">{exp.company}</p>
                  <span class="inline-block mt-2 px-2 py-1 text-xs font-medium text-zinc-500 border border-zinc-700 rounded">
                    {exp.type}
                  </span>
                </>
              )}
              {index % 2 !== 0 && (
                <>
                  <p class="text-sm text-zinc-500 mb-2">{exp.period}</p>
                  <h3 class="text-xl font-semibold text-zinc-100">{exp.title}</h3>
                  <p class="text-zinc-400 mt-1">{exp.company}</p>
                  <span class="inline-block mt-2 px-2 py-1 text-xs font-medium text-zinc-500 border border-zinc-700 rounded">
                    {exp.type}
                  </span>
                </>
              )}
            </div>
            
            <div class={`relative ${index % 2 === 0 ? 'md:col-start-2 md:pl-12' : 'md:pr-12'}`}>
              <div class="absolute left-0 top-2 w-3 h-3 rounded-full border-2 border-zinc-600 bg-zinc-900 -translate-x-[1.625rem] hidden md:block"></div>
              
              <div class="space-y-4">
                <ul class="space-y-3">
                  {exp.highlights.map((highlight) => (
                    <li class="flex items-start gap-3 text-zinc-400">
                      <span class="mt-2 w-1.5 h-1.5 rounded-full bg-zinc-700 flex-shrink-0"></span>
                      {highlight}
                    </li>
                  ))}
                </ul>
                
                <div class="flex flex-wrap gap-2 pt-2">
                  {exp.technologies.map((tech) => (
                    <span class="px-2 py-1 text-xs text-zinc-500 bg-zinc-900 border border-zinc-800 rounded">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
