---
import Card from "./Card.astro";
import ReactIcon from "./icons/ReactIcon.astro";

const PROJECTS = [
  {
    title: "Evidence Warehouse System",
    description:
      "Designed and implemented a digital evidence management system using microservices architecture. Node.js + WebSockets for real-time communication, React frontend, Laravel + TypeScript backend, and LibreOffice integration for document collaboration. Serving 50+ government agencies.",
    image: "/imgs/projects/nomina.png",
    company: "FGJEM",
    time: "2024",
  },
  {
    title: "Pre-Denuncia Online",
    description:
      "Built an online pre-complaint reporting system with Next.js (TypeScript), MySQL, and Prisma ORM. Implemented Docker containers and CI/CD pipelines with GitHub Actions for automated deployments and testing.",
    link: "https://fgjem.edomex.gob.mx/pre-denuncia-en-linea",
    image: "/imgs/projects/predenuncia.png",
    company: "FGJEM",
    time: "2024",
  },
  {
    title: "Payroll System",
    description:
      "Maintained and enhanced the payroll system processing 1M+ stamps daily. React.js + PHP (Laravel) with MySQL. Implemented automated GitHub Actions deployments and Docker with semantic versioning for controlled releases.",
    image: "/imgs/projects/ecommerce.webp",
    company: "FGJEM",
    time: "2024",
  },
  {
    title: "Risk Questionnaire System",
    description:
      "Designed REST API with hexagonal architecture in PHP, JWT authentication, PDF/Excel report generation. React + TypeScript + Tailwind CSS frontend. Reduced retrieval time by 60% through optimized queries.",
    link: "https://miigecem.edomex.gob.mx/cuestionario/",
    github: "https://github.com/DuarteDc/FDRPSE",
    image: "/imgs/projects/cuestionario.webp",
    company: "IGECEM",
    time: "2023",
  },
  {
    title: "E-Commerce Platform",
    description:
      "Built scalable e-commerce for beauty products with Next.js, Tailwind CSS, and Redux. Clean code practices and scalable architecture for thousands of users. Integrated payment gateways and real-time inventory.",
    link: "https://wapizima.com/",
    image: "/imgs/projects/wos.webp",
    company: "Digital Pineapple",
    time: "2022",
  }
];

const personalProjects = [
  {
    name: "stepper-ui",
    description: "React component library for multi-step forms and workflows. Published to npm with 2.5k+ weekly downloads.",
    npm: "https://www.npmjs.com/package/stepper-ui",
    github: "https://github.com/DuarteDc/stepper-ui-library",
    demo: "/demo/stepper-ui"
  }
];
---

<section
  id="projects"
  class="w-full lg:py-20 text-white overflow-hidden relative"
>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[80%] lg:w-[60%] h-[30rem] lg:h-[40rem] bg-purple-500/20 rounded-bl-full rounded-br-full blur-[8rem] -z-10"></div>
  
  <h3
    class="text-center bg-gradient-to-r from-purple-400 to-purple-200 inline-block text-transparent py-5 bg-clip-text text-4xl lg:text-6xl font-bold uppercase font-[Poppins] w-full"
  >
    Featured Projects
  </h3>

  <p class="text-center text-gray-400 mt-4 mb-12 max-w-2xl mx-auto">
    Backend systems and architectural solutions designed for scale, reliability, and real-world impact
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {PROJECTS.map((project) => <Card {...project} />)}
  </div>

  <div class="mt-16 flex flex-col gap-5">
    <hr class="h-[1px] w-full border-gray-800" />
    <h4
      class="text-center bg-gradient-to-r from-purple-400 to-purple-200 inline-block text-transparent py-3 bg-clip-text text-2xl lg:text-3xl font-bold uppercase font-[Poppins] w-full"
    >
      Open Source
    </h4>
    <div
      class="max-w-2xl mx-auto w-full rounded-xl bg-gray-900/50 border border-gray-800 hover:border-purple-500/30 p-6 transition-all duration-300"
    >
      <div class="flex items-center gap-3 mb-4">
        <ReactIcon />
        <p class="text-xl font-semibold text-purple-300">stepper-ui</p>
      </div>
      <p class="text-gray-400 text-sm leading-relaxed">
        {personalProjects[0].description}
      </p>
      <div class="flex flex-wrap gap-4 mt-5">
        <a
          href={personalProjects[0].npm}
          target="_blank"
          class="text-sm px-4 py-2 rounded-md border border-gray-700 hover:border-purple-500 hover:bg-purple-500/10 transition-all duration-300"
          rel="noopener noreferrer">npm</a
        >
        <a
          href={personalProjects[0].github}
          target="_blank"
          class="text-sm px-4 py-2 rounded-md border border-gray-700 hover:border-purple-500 hover:bg-purple-500/10 transition-all duration-300"
          rel="noopener noreferrer">GitHub</a
        >
        <a
          href={personalProjects[0].demo}
          class="text-sm px-4 py-2 rounded-md border border-gray-700 hover:border-purple-500 hover:bg-purple-500/10 transition-all duration-300"
          rel="noopener noreferrer">Demo</a
        >
      </div>
    </div>
  </div>
</section>
