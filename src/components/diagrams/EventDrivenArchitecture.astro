---
---

<div class="w-full overflow-x-auto">
  <svg viewBox="0 0 900 400" class="w-full min-w-[700px] h-auto">
    <defs>
      <marker id="arrow" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <polygon points="0 0, 10 3.5, 0 7" fill="#a78bfa" />
      </marker>
      <marker id="arrow-green" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <polygon points="0 0, 10 3.5, 0 7" fill="#4ade80" />
      </marker>
      <marker id="arrow-red" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <polygon points="0 0, 10 3.5, 0 7" fill="#f87171" />
      </marker>
      <marker id="arrow-yellow" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <polygon points="0 0, 10 3.5, 0 7" fill="#fbbf24" />
      </marker>
      <filter id="glow-purple" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
        <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <filter id="glow-green" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
        <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color:#1e1e2e;stop-opacity:1" />
        <stop offset="100%" style="stop-color:#18181b;stop-opacity:1" />
      </linearGradient>
    </defs>

    <rect x="20" y="20" width="860" height="360" rx="12" fill="url(#bgGrad)" stroke="#27272a" stroke-width="1"/>

    <text x="50" y="50" fill="#a78bfa" font-size="11" font-weight="600" font-family="sans-serif" letter-spacing="1">PAYROLL STAMPING SYSTEM — EVENT-DRIVEN ARCHITECTURE</text>

    <g>
      <rect x="50" y="80" width="120" height="60" rx="8" fill="#1e293b" stroke="#60a5fa" stroke-width="2"/>
      <text x="110" y="105" text-anchor="middle" fill="#60a5fa" font-size="11" font-weight="500" font-family="sans-serif">HR System</text>
      <text x="110" y="122" text-anchor="middle" fill="#94a3b8" font-size="9" font-family="monospace">(Producer)</text>
    </g>

    <line x1="170" y1="110" x2="220" y2="110" stroke="#60a5fa" stroke-width="2" marker-end="url(#arrow)"/>

    <g filter="url(#glow-purple)">
      <rect x="220" y="75" width="160" height="70" rx="10" fill="#581c87" stroke="#a78bfa" stroke-width="2"/>
      <text x="300" y="100" text-anchor="middle" fill="#e9d5ff" font-size="12" font-weight="500" font-family="sans-serif">API Endpoint</text>
      <text x="300" y="118" text-anchor="middle" fill="#c4b5fd" font-size="10" font-family="monospace">POST /payroll/stamp</text>
      <text x="300" y="135" text-anchor="middle" fill="#a78bfa" font-size="9" font-family="monospace">Validation + Auth</text>
    </g>

    <line x1="380" y1="110" x2="430" y2="110" stroke="#a78bfa" stroke-width="2" marker-end="url(#arrow)"/>

    <g filter="url(#glow-purple)">
      <rect x="430" y="70" width="140" height="80" rx="10" fill="#713f12" stroke="#fbbf24" stroke-width="2"/>
      <text x="500" y="95" text-anchor="middle" fill="#fde68a" font-size="12" font-weight="600" font-family="monospace">RabbitMQ</text>
      <text x="500" y="115" text-anchor="middle" fill="#fef3c7" font-size="9" font-family="monospace">payroll.stamp</text>
      <text x="500" y="130" text-anchor="middle" fill="#fef3c7" font-size="9" font-family="monospace">exchange</text>
      <rect x="460" y="138" width="80" height="6" rx="3" fill="#fbbf24" opacity="0.4"/>
      <rect x="460" y="138" width="50" height="6" rx="3" fill="#fbbf24"/>
    </g>

    <line x1="500" y1="150" x2="500" y2="190" stroke="#fbbf24" stroke-width="2" marker-end="url(#arrow-yellow)"/>

    <g filter="url(#glow-green)">
      <rect x="430" y="190" width="140" height="50" rx="8" fill="#14532d" stroke="#4ade80" stroke-width="2"/>
      <text x="500" y="215" text-anchor="middle" fill="#86efac" font-size="11" font-weight="500" font-family="sans-serif">Worker Pool</text>
      <text x="500" y="230" text-anchor="middle" fill="#6b7280" font-size="9" font-family="monospace">3 concurrent</text>
    </g>

    <line x1="570" y1="215" x2="620" y2="215" stroke="#4ade80" stroke-width="2" marker-end="url(#arrow-green)"/>

    <g filter="url(#glow-green)">
      <rect x="620" y="190" width="100" height="50" rx="8" fill="#7f1d1d" stroke="#f87171" stroke-width="2"/>
      <text x="670" y="212" text-anchor="middle" fill="#fecaca" font-size="11" font-weight="500" font-family="monospace">Redis</text>
      <text x="670" y="227" text-anchor="middle" fill="#fca5a5" font-size="9" font-family="monospace">Cache + Rate</text>
    </g>

    <line x1="670" y1="240" x2="670" y2="280" stroke="#f87171" stroke-width="2" marker-end="url(#arrow-red)"/>

    <g>
      <rect x="600" y="280" width="140" height="55" rx="8" fill="#1e293b" stroke="#6b7280" stroke-width="1.5"/>
      <text x="670" y="302" text-anchor="middle" fill="#e5e7eb" font-size="10" font-weight="500" font-family="sans-serif">MySQL Database</text>
      <text x="670" y="318" text-anchor="middle" fill="#6b7280" font-size="9" font-family="monospace">Stamped Records</text>
    </g>

    <g>
      <rect x="50" y="180" width="120" height="45" rx="8" fill="#1e293b" stroke="#6b7280" stroke-width="1.5"/>
      <text x="110" y="200" text-anchor="middle" fill="#94a3b8" font-size="10" font-family="sans-serif">Retry Queue</text>
      <text x="110" y="215" text-anchor="middle" fill="#6b7280" font-size="9" font-family="monospace">DLX on failure</text>
    </g>
    <line x1="430" y1="200" x2="170" y2="200" stroke="#6b7280" stroke-width="1" stroke-dasharray="4"/>
    <line x1="170" y1="200" x2="170" y2="280" stroke="#6b7280" stroke-width="1" stroke-dasharray="4"/>
    <line x1="170" y1="280" x2="600" y2="280" stroke="#6b7280" stroke-width="1" stroke-dasharray="4"/>

    <g>
      <rect x="50" y="300" width="100" height="50" rx="8" fill="#1e293b" stroke="#22d3ee" stroke-width="1.5"/>
      <text x="100" y="320" text-anchor="middle" fill="#a5f3fc" font-size="10" font-weight="500" font-family="sans-serif">Dashboard</text>
      <text x="100" y="335" text-anchor="middle" fill="#67e8f9" font-size="9" font-family="monospace">SSE Stream</text>
    </g>

    <line x1="500" y1="215" x2="500" y2="300" stroke="#22d3ee" stroke-width="1" stroke-dasharray="4"/>
    <line x1="500" y1="300" x2="150" y2="300" stroke="#22d3ee" stroke-width="1" stroke-dasharray="4"/>

    <text x="50" y="375" fill="#6b7280" font-size="9" font-family="monospace">1M+ stamps/day · 99.9% uptime · Horizontal scaling</text>

    <g transform="translate(720, 80)">
      <rect x="0" y="0" width="140" height="200" rx="8" fill="#18181b" stroke="#27272a" stroke-width="1"/>
      <text x="70" y="25" text-anchor="middle" fill="#a78bfa" font-size="10" font-weight="600" font-family="sans-serif">KEY DECISIONS</text>
      
      <text x="15" y="55" fill="#4ade80" font-size="9" font-family="monospace">✓ Decoupled workers</text>
      <text x="15" y="75" fill="#94a3b8" font-size="8" font-family="sans-serif">  via message queue</text>
      
      <text x="15" y="100" fill="#4ade80" font-size="9" font-family="monospace">✓ Redis rate limiting</text>
      <text x="15" y="120" fill="#94a3b8" font-size="8" font-family="sans-serif">  prevents overload</text>
      
      <text x="15" y="145" fill="#4ade80" font-size="9" font-family="monospace">✓ DLX for retries</text>
      <text x="15" y="165" fill="#94a3b8" font-size="8" font-family="sans-serif">  dead letters queue</text>
      
      <text x="15" y="190" fill="#22d3ee" font-size="9" font-family="monospace">✓ SSE for real-time</text>
    </g>
  </svg>
</div>
