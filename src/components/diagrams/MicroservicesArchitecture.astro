---
---

<div class="w-full overflow-x-auto">
  <svg viewBox="0 0 550 320" class="w-full min-w-[450px] h-auto">
    <defs>
      <marker id="arrPurple" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#a78bfa" />
      </marker>
      <marker id="arrZinc" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#71717a" />
      </marker>
      <marker id="arrGreen" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#4ade80" />
      </marker>
    </defs>

    <rect x="200" y="20" width="150" height="45" rx="6" fill="#3f3f46" stroke="#a78bfa" stroke-width="2"/>
    <text x="275" y="48" text-anchor="middle" fill="#e4e4e7" font-size="11" font-weight="600" font-family="sans-serif">API Gateway</text>

    <line x1="275" y1="65" x2="275" y2="90" stroke="#a78bfa" stroke-width="2" marker-end="url(#arrPurple)"/>

    <rect x="50" y="100" width="100" height="50" rx="6" fill="#27272a" stroke="#3f3f46" stroke-width="1.5"/>
    <text x="100" y="125" text-anchor="middle" fill="#a1a1aa" font-size="10" font-family="sans-serif">Auth Service</text>
    <text x="100" y="140" text-anchor="middle" fill="#71717a" font-size="8" font-family="sans-serif">JWT / OAuth</text>

    <rect x="175" y="100" width="100" height="50" rx="6" fill="#27272a" stroke="#3f3f46" stroke-width="1.5"/>
    <text x="225" y="125" text-anchor="middle" fill="#a1a1aa" font-size="10" font-family="sans-serif">Evidence API</text>
    <text x="225" y="140" text-anchor="middle" fill="#71717a" font-size="8" font-family="sans-serif">Core Domain</text>

    <rect x="300" y="100" width="100" height="50" rx="6" fill="#27272a" stroke="#3f3f46" stroke-width="1.5"/>
    <text x="350" y="125" text-anchor="middle" fill="#a1a1aa" font-size="10" font-family="sans-serif">Reports API</text>
    <text x="350" y="140" text-anchor="middle" fill="#71717a" font-size="8" font-family="sans-serif">PDF / Excel</text>

    <rect x="425" y="100" width="100" height="50" rx="6" fill="#27272a" stroke="#3f3f46" stroke-width="1.5"/>
    <text x="475" y="125" text-anchor="middle" fill="#a1a1aa" font-size="10" font-family="sans-serif">Notifications</text>
    <text x="475" y="140" text-anchor="middle" fill="#71717a" font-size="8" font-family="sans-serif">WebSockets</text>

    <line x1="275" y1="90" x2="100" y2="100" stroke="#a78bfa" stroke-width="1.5" marker-end="url(#arrPurple)"/>
    <line x1="275" y1="90" x2="225" y2="100" stroke="#a78bfa" stroke-width="1.5" marker-end="url(#arrPurple)"/>
    <line x1="275" y1="90" x2="350" y2="100" stroke="#a78bfa" stroke-width="1.5" marker-end="url(#arrPurple)"/>
    <line x1="275" y1="90" x2="475" y2="100" stroke="#a78bfa" stroke-width="1.5" marker-end="url(#arrPurple)"/>

    <rect x="100" y="180" width="350" height="35" rx="6" fill="#1c1917" stroke="#fbbf24" stroke-width="1.5"/>
    <text x="275" y="203" text-anchor="middle" fill="#fde68a" font-size="11" font-weight="500" font-family="monospace">RabbitMQ Message Bus</text>

    <line x1="100" y1="150" x2="100" y2="180" stroke="#71717a" stroke-width="1" marker-end="url(#arrZinc)"/>
    <line x1="225" y1="150" x2="175" y2="180" stroke="#71717a" stroke-width="1" marker-end="url(#arrZinc)"/>
    <line x1="350" y1="150" x2="375" y2="180" stroke="#71717a" stroke-width="1" marker-end="url(#arrZinc)"/>
    <line x1="475" y1="150" x2="450" y2="180" stroke="#71717a" stroke-width="1" marker-end="url(#arrZinc)"/>

    <rect x="60" y="235" width="80" height="35" rx="4" fill="#27272a" stroke="#3f3f46" stroke-width="1"/>
    <text x="100" y="256" text-anchor="middle" fill="#a1a1aa" font-size="9" font-family="sans-serif">Auth DB</text>

    <rect x="160" y="235" width="80" height="35" rx="4" fill="#27272a" stroke="#3f3f46" stroke-width="1"/>
    <text x="200" y="256" text-anchor="middle" fill="#a1a1aa" font-size="9" font-family="sans-serif">Evidence DB</text>

    <rect x="260" y="235" width="80" height="35" rx="4" fill="#27272a" stroke="#3f3f46" stroke-width="1"/>
    <text x="300" y="256" text-anchor="middle" fill="#a1a1aa" font-size="9" font-family="sans-serif">Reports DB</text>

    <rect x="360" y="235" width="80" height="35" rx="4" fill="#27272a" stroke="#3f3f46" stroke-width="1"/>
    <text x="400" y="256" text-anchor="middle" fill="#a1a1aa" font-size="9" font-family="sans-serif">Notify DB</text>

    <line x1="100" y1="215" x2="100" y2="235" stroke="#4ade80" stroke-width="1.5" marker-end="url(#arrGreen)"/>
    <line x1="200" y1="215" x2="200" y2="235" stroke="#4ade80" stroke-width="1.5" marker-end="url(#arrGreen)"/>
    <line x1="300" y1="215" x2="300" y2="235" stroke="#4ade80" stroke-width="1.5" marker-end="url(#arrGreen)"/>
    <line x1="400" y1="215" x2="400" y2="235" stroke="#4ade80" stroke-width="1.5" marker-end="url(#arrGreen)"/>

    <rect x="460" y="180" width="70" height="30" rx="4" fill="#27272a" stroke="#f87171" stroke-width="1"/>
    <text x="495" y="199" text-anchor="middle" fill="#fca5a5" font-size="8" font-family="sans-serif">Redis Cache</text>
    <line x1="460" y1="197" x2="450" y2="197" stroke="#71717a" stroke-width="1" marker-end="url(#arrZinc)"/>

    <text x="275" y="300" text-anchor="middle" fill="#52525b" font-size="8" font-family="sans-serif">Microservices with Database-per-Service Pattern</text>
  </svg>
</div>
