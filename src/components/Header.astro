---
import GithubIcon from "./icons/GithubIcon.astro";
import LinkedinIcon from "./icons/LinkedinIcon.astro";
import DownloadIcon from "./icons/DownloadIcon.astro";
---

<header
  id="about-me"
  class="min-h-[calc(100vh-10rem)] w-full flex flex-col lg:flex-row items-center justify-center text-white gap-4 lg:gap-10"
>
  <span
    class="w-[20rem] h-[30rem] xl:w-[70rem] xl:h-[50rem] rounded-full bg-purple-500/15 blur-[10rem] absolute left-20 -z-10"
  ></span>
  <div
    class="w-[250px] h-[250px] xl:w-[400px] xl:h-[400px] rounded-full overflow-hidden main-image relative"
  >
    <img
      src="/imgs/me-pixel-art-no-bg.png"
      alt="Eduardo Duarte"
      class="w-full h-full object-cover mix-blend-lighten shadow-2xl"
    />
  </div>
  <div class="w-full xl:w-6/12">
    <span class="flex items-center gap-4">
      <hr
        class="h-[1px] w-[6rem] bg-gradient-to-l from-purple-500 to-purple-900 border-none"
      />
      <p class="text-gray-400 text-sm tracking-widest uppercase">Portfolio</p>
    </span>
    <h1
      class="text-[3.5rem] lg:text-[5rem] xl:text-[7rem] break-words w-full leading-none font-[Poppins] bg-gradient-to-t from-purple-400 to-purple-100 inline-block text-transparent py-3 bg-clip-text text-4xl lg:text-6xl font-bold"
    >
      Eduardo Duarte <b
        class="bg-gradient-to-t from-purple-600 to-purple-100 inline-block text-transparent py-3 bg-clip-text font-bold"
        >.</b
      >
    </h1>
    <div class="flex flex-col gap-2 mt-2">
      <p class="text-purple-400 text-lg lg:text-xl font-semibold tracking-wide">
        Senior Backend Engineer
      </p>
      <p class="text-purple-400/70 text-base lg:text-lg font-medium">
        Jefe de Departamento · Technical Lead
      </p>
    </div>
    <p class="lg:mt-8 break-words w-full lg:w-9/12 text-sm lg:text-base text-gray-400 leading-relaxed">
      Building and scaling distributed backend systems with 4+ years of experience. Leading technical departments, designing microservices architectures, and orchestrating containerized deployments at scale.
    </p>
    <div class="mt-8 flex flex-wrap items-center gap-3 relative z-20">
      <a
        href="https://mx.linkedin.com/in/duartedc"
        type="button"
        target="_blank"
        class="flex items-center gap-2 px-5 py-2.5 rounded-md bg-purple-600 hover:bg-purple-500 transition-all duration-300 font-medium"
      >
        <LinkedinIcon width="18" height="18" />
        LinkedIn
      </a>
      <a
        href="https://github.com/DuarteDc"
        type="button"
        target="_blank"
        class="flex items-center gap-2 px-5 py-2.5 rounded-md border border-gray-700 hover:border-purple-500 hover:bg-purple-500/10 transition-all duration-300 font-medium"
      >
        <GithubIcon width="18" height="18" />
        GitHub
      </a>
      <a
        href="/EduardoDuarteCv.pdf"
        download
        type="button"
        class="flex items-center gap-2 px-5 py-2.5 rounded-md border border-gray-700 hover:border-cyan-500 hover:bg-cyan-500/10 transition-all duration-300 font-medium text-cyan-400"
      >
        <DownloadIcon width="18" height="18" />
        Descargar CV
      </a>
    </div>
  </div>
</header>
