---
import Layout from "../../layouts/Layout.astro";
import CalendarIcon from "../../components/icons/CalendarIcon.astro";
import ArrowLeftIcon from "../../components/icons/ArrowLeftIcon.astro";

const posts = [
  {
    slug: "semantic-version-docker",
    title: "How to Create Docker Images with Semantic Versioning using GitHub Actions",
    description: "A step-by-step guide to automate Docker image versioning with semantic release and GitHub Actions for production-ready deployments.",
    date: "2024-12-15",
    readingTime: 8,
    tags: ["Docker", "GitHub Actions", "DevOps", "CI/CD"]
  }
];
---

<Layout title="Blog | Eduardo Duarte" description="Technical articles and tutorials about backend development, system architecture, and DevOps practices.">
  <div class="max-w-4xl mx-auto px-6 py-16">
    <header class="mb-16">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-zinc-200 transition-colors mb-8"
      >
        <ArrowLeftIcon width="16" height="16" />
        Back to portfolio
      </a>
      
      <h1 class="text-4xl md:text-5xl font-bold text-zinc-100 mb-4">
        Blog
      </h1>
      <p class="text-lg text-zinc-400 max-w-2xl">
        Technical articles, tutorials, and insights from my experience building distributed systems and leading engineering teams.
      </p>
    </header>

    <section class="space-y-8">
      {posts.map((post) => (
        <article class="group">
          <a href={`/post/${post.slug}`} class="block">
            <div class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-8 hover:border-zinc-700 transition-colors">
              <div class="flex flex-wrap gap-2 mb-4">
                {post.tags.map((tag) => (
                  <span class="px-3 py-1 text-xs font-medium text-zinc-500 border border-zinc-700 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
              
              <h2 class="text-xl font-semibold text-zinc-100 mb-3 group-hover:text-zinc-200 transition-colors">
                {post.title}
              </h2>
              
              <p class="text-zinc-400 mb-4 line-clamp-2">
                {post.description}
              </p>
              
              <div class="flex items-center gap-4 text-sm text-zinc-500">
                <div class="flex items-center gap-2">
                  <CalendarIcon width="14" height="14" />
                  <time datetime={post.date}>
                    {new Date(post.date).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                    })}
                  </time>
                </div>
                <span>{post.readingTime} min read</span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </section>

    {posts.length === 0 && (
      <div class="text-center py-16">
        <p class="text-zinc-500">No posts yet. Check back soon!</p>
      </div>
    )}
  </div>
</Layout>
